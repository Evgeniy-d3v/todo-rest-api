        "/tasks/{taskId}/tags": {
            "put": {
                "tags": [
                    "Tasks",
                    "Tags"
                ],
                "summary": "Синхронизировать список тегов задачи",
                "operationId": "5ea91c40acdacb20c48b46675589059b",
                "parameters": [
                    {
                        "name": "taskId",
                        "in": "path",
                        "description": "ID задачи",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
