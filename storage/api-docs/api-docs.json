    "components": {
        "schemas": {
            "Task": {
                "required": [
                    "id",
                    "title",
                    "description",
                    "status",
                    "priority",
                    "due_at"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "title": {
                        "type": "string",
                        "example": "Buy milk"
                    },
                    "description": {
                        "type": "string",
                        "example": "Need to buy milk on the way home"
                    },
                    "status": {
                        "description": "Enum TaskStatusEnum",
                        "type": "string",
                        "example": "todo"
                    },
                    "priority": {
                        "description": "Enum TaskPriorityEnum",
                        "type": "string",
                        "example": "high"
                    },
                    "due_at": {
                        "description": "Unix timestamp",
                        "type": "string",
                        "example": "2024-03-09 16:00:00"
                    },
                    "tags": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Tag"
                        }
                    }
                },
                "type": "object"
            },
            "Tag": {
                "required": [
                    "id",
                    "description"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "description": {
                        "type": "string",
                        "example": "Personal"
                    }
                },
                "type": "object"
            },
            "StoreTaskRequest": {
                "required": [
                    "title",
                    "description",
                    "status",
                    "priority",
                    "due_at"
                ],
                "properties": {
                    "title": {
                        "type": "string",
                        "maxLength": 255
                    },
                    "description": {
                        "type": "string"
                    },
                    "status": {
                        "description": "TaskStatusEnum value",
                        "type": "string"
                    },
                    "priority": {
                        "description": "TaskPriorityEnum value",
                        "type": "string"
                    },
                    "due_at": {
                        "description": "Дата/время, парсится в timestamp",
                        "type": "string"
                    }
                },
                "type": "object"
            },
            "UpdateTaskRequest": {
                "properties": {
                    "title": {
                        "type": "string",
                        "maxLength": 255
                    },
                    "description": {
                        "type": "string",
                        "nullable": true
                    },
                    "status": {
                        "description": "TaskStatusEnum value",
                        "type": "string"
                    },
                    "priority": {
                        "description": "TaskPriorityEnum value",
                        "type": "string"
                    },
                    "due_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "SyncTagsRequest": {
                "required": [
                    "tagsIdList"
                ],
                "properties": {
                    "tagsIdList": {
                        "type": "array",
                        "items": {
                            "type": "integer"
                        },
                        "maxItems": 255
                    }
                },
                "type": "object"
            },
            "StoreTagRequest": {
                "required": [
                    "description"
                ],
                "properties": {
                    "description": {
                        "type": "string"
                    }
                },
                "type": "object"
            },
            "UpdateTagRequest": {
                "required": [
                    "description"
                ],
                "properties": {
                    "description": {
                        "type": "string"
                    }
                },
                "type": "object"
            },
            "BaseSuccessEnvelope": {
                "properties": {
                    "success": {
                        "type": "boolean",
                        "example": true
                    },
                    "data": {}
                },
                "type": "object"
            },
            "BaseErrorEnvelope": {
                "properties": {
                    "success": {
                        "type": "boolean",
                        "example": false
                    },
                    "data": {}
                },
                "type": "object"
            },
            "TaskSuccessResponse": {
                "allOf": [
                    {
                        "$ref": "#/components/schemas/BaseSuccessEnvelope"
                    },
                    {
                        "properties": {
                            "data": {
                                "$ref": "#/components/schemas/Task"
                            }
                        },
                        "type": "object"
                    }
                ]
            },
            "TagSuccessResponse": {
                "allOf": [
                    {
                        "$ref": "#/components/schemas/BaseSuccessEnvelope"
                    },
                    {
                        "properties": {
                            "data": {
                                "$ref": "#/components/schemas/Tag"
                            }
                        },
                        "type": "object"
                    }
                ]
            },
            "TagListResponse": {
                "allOf": [
                    {
                        "$ref": "#/components/schemas/BaseSuccessEnvelope"
                    },
                    {
                        "properties": {
                            "data": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/components/schemas/Tag"
                                }
                            }
                        },
                        "type": "object"
                    }
                ]
            },
            "ErrorResponse": {
                "allOf": [
                    {
                        "$ref": "#/components/schemas/BaseErrorEnvelope"
                    },
                    {
                        "properties": {
                            "data": {
                                "type": "string",
                                "example": "Задача с айди 1 не найдена",
                                "nullable": true
                            }
                        },
                        "type": "object"
                    }
                ]
            },
            "ValidationErrorResponse": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Validation failed. (title field is required)"
                    }
                },
                "type": "object"
            }
        }
    },
    "tags": [
        {
            "name": "Tags",
            "description": "Tags"
        },
        {
            "name": "Tasks",
            "description": "Tasks"
        }
    ]
}