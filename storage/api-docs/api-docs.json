                ],
                "summary": "Прикрепить тег к задаче",
                "operationId": "533c75bb903a52326bac8e46affd03d7",
                "parameters": [
                    {
                        "name": "taskId",
                        "in": "path",
                        "description": "ID задачи",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "tagId",
                        "in": "path",
                        "description": "ID тега",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Задача с обновлёнными тегами",
                        "content": {
                            "application/json": {
                                "schema": {
