                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Задача или тег не найдены",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    }
                }
            },
